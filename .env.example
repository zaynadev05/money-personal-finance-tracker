# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE CONFIGURATION: Required for persistent cloud database features in Monify.
# Paste your Supabase project credentials below.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-role-public-api-key"

# DIRECT PORTGRESQL / SQL DATABASE CONNECTION (FOR EXTERNAL CLIENTS OR VS CODE):
# These can be used with postgreSQL clients (pgAdmin, DBeaver, or command line).
# Do not share secrets with client-side applications.
DB_HOST="aws-0-us-east-1.pooler.supabase.com"
DB_PORT="6543"
DB_USER="postgres.your-project-id"
DB_PASSWORD="your-db-strong-password"
DB_NAME="postgres"

